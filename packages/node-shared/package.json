{
  "name": "@cogni/node-shared",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./analytics": "./src/analytics/index.ts",
    "./ai": "./src/ai/index.ts",
    "./auth": "./src/auth/index.ts",
    "./auth/link-intent-store": "./src/auth/link-intent-store.ts",
    "./auth/scheduler-token": "./src/auth/scheduler-token.ts",
    "./auth/session": "./src/auth/session.ts",
    "./constants": "./src/constants/index.ts",
    "./crypto/aead": "./src/crypto/aead.ts",
    "./errors": "./src/errors/index.ts",
    "./observability": "./src/observability/index.ts",
    "./observability/client": "./src/observability/client/index.ts",
    "./observability/context": "./src/observability/context/index.ts",
    "./observability/events/ai": "./src/observability/events/ai.ts",
    "./observability/events": "./src/observability/events/index.ts",
    "./observability/events/payments": "./src/observability/events/payments.ts",
    "./observability/server": "./src/observability/server/index.ts",
    "./time/time-range": "./src/time/time-range.ts",
    "./util": "./src/util/index.ts",
    "./utils/money": "./src/utils/money.ts",
    "./web3": "./src/web3/index.ts"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs'); if(!fs.existsSync('dist/index.js')){console.error('ERROR: dist/index.js missing'); process.exit(1)}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cogni/ai-core": "workspace:*",
    "@cogni/node-core": "workspace:*",
    "@cogni/repo-spec": "workspace:*",
    "fast-safe-stringify": "^2.1.1",
    "uuid": "^11.1.0",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "pino": "^9"
  },
  "peerDependenciesMeta": {
    "pino": {
      "optional": true
    }
  },
  "devDependencies": {
    "pino": "^9.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
