{
  "name": "@cogni/db-schema",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./refs": {
      "types": "./dist/refs.d.ts",
      "import": "./dist/refs.js",
      "default": "./dist/refs.js"
    },
    "./scheduling": {
      "types": "./dist/scheduling.d.ts",
      "import": "./dist/scheduling.js",
      "default": "./dist/scheduling.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "default": "./dist/auth.js"
    },
    "./billing": {
      "types": "./dist/billing.d.ts",
      "import": "./dist/billing.js",
      "default": "./dist/billing.js"
    },
    "./copy-trade": {
      "types": "./dist/copy-trade.d.ts",
      "import": "./dist/copy-trade.js",
      "default": "./dist/copy-trade.js"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js",
      "default": "./dist/ai.js"
    },
    "./ai-threads": {
      "types": "./dist/ai-threads.d.ts",
      "import": "./dist/ai-threads.js",
      "default": "./dist/ai-threads.js"
    },
    "./identity": {
      "types": "./dist/identity.d.ts",
      "import": "./dist/identity.js",
      "default": "./dist/identity.js"
    },
    "./attribution": {
      "types": "./dist/attribution.d.ts",
      "import": "./dist/attribution.js",
      "default": "./dist/attribution.js"
    },
    "./poly-redeem-jobs": {
      "types": "./dist/poly-redeem-jobs.d.ts",
      "import": "./dist/poly-redeem-jobs.js",
      "default": "./dist/poly-redeem-jobs.js"
    },
    "./profile": {
      "types": "./dist/profile.d.ts",
      "import": "./dist/profile.js",
      "default": "./dist/profile.js"
    },
    "./trader-activity": {
      "types": "./dist/trader-activity.d.ts",
      "import": "./dist/trader-activity.js",
      "default": "./dist/trader-activity.js"
    },
    "./wallet-connections": {
      "types": "./dist/wallet-connections.d.ts",
      "import": "./dist/wallet-connections.js",
      "default": "./dist/wallet-connections.js"
    },
    "./wallet-grants": {
      "types": "./dist/wallet-grants.d.ts",
      "import": "./dist/wallet-grants.js",
      "default": "./dist/wallet-grants.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs'); for(const f of ['dist/index.js','dist/refs.js','dist/copy-trade.js','dist/poly-redeem-jobs.js','dist/trader-activity.js','dist/wallet-connections.js','dist/wallet-grants.js']){if(!fs.existsSync(f)){console.error('ERROR: '+f+' missing'); process.exit(1)}}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
