{
  "name": "@cogni/poly-market-provider",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters/polymarket": {
      "types": "./dist/adapters/polymarket/index.d.ts",
      "import": "./dist/adapters/polymarket/index.js",
      "default": "./dist/adapters/polymarket/index.js"
    },
    "./adapters/kalshi": {
      "types": "./dist/adapters/kalshi/index.d.ts",
      "import": "./dist/adapters/kalshi/index.js",
      "default": "./dist/adapters/kalshi/index.js"
    },
    "./adapters/paper": {
      "types": "./dist/adapters/paper/index.d.ts",
      "import": "./dist/adapters/paper/index.js",
      "default": "./dist/adapters/paper/index.js"
    },
    "./analysis": {
      "types": "./dist/analysis/index.d.ts",
      "import": "./dist/analysis/index.js",
      "default": "./dist/analysis/index.js"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "import": "./dist/policy/index.js",
      "default": "./dist/policy/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs'); if(!fs.existsSync('dist/index.js')){console.error('ERROR: dist/index.js missing'); process.exit(1)}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:ci": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@polymarket/clob-client-v2": "^1.0.2",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.9",
    "viem": "^2.0.0"
  }
}
